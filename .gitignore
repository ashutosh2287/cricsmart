# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ml artifacts
ml/.venv/
ml/models/*.joblib
ml/models/*.pkl
ml/datasets/processed/
# python
__pycache__/
*.py[cod]
*.pyc

# commentary ml artifacts
ml/commentary/embeddings/artifacts/
ml/commentary/retrieval/*.joblib
ml/commentary/models/*.joblib
ml/commentary/models/*.json
!ml/commentary/models/feature_contract.json
!ml/commentary/models/runtime_thresholds.json
ml/commentary/datasets/processed/
ml/commentary/evaluation/*.json
ml/commentary/evaluation/*.md
