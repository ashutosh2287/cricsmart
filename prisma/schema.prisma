generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         String   @default("public")
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model HostedMatch {
  id             String   @id @default(cuid())
  externalMatchId String? @unique
  teamA          String
  teamB          String
  type           String   @default("LIVE")
  runtimeMatchId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
