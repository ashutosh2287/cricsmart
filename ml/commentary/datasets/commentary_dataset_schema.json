{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CommentaryDatasetRow",
  "type": "object",
  "required": [
    "match_id",
    "innings",
    "over",
    "ball",
    "batting_team",
    "bowling_team",
    "striker",
    "non_striker",
    "bowler",
    "runs",
    "wicket",
    "extras",
    "current_score",
    "wickets_lost",
    "required_rr",
    "current_rr",
    "target",
    "balls_remaining",
    "recent_runs",
    "recent_wickets",
    "dot_ball_streak",
    "partnership_runs",
    "partnership_balls",
    "phase_of_match",
    "win_probability",
    "momentum_state",
    "pressure_level",
    "collapse_risk",
    "commentary_text",
    "commentary_type",
    "tone",
    "importance",
    "pressure_score",
    "momentum_score",
    "collapse_score",
    "partnership_strength",
    "boundary_frequency",
    "dot_ball_pressure",
    "probability_swing",
    "death_over_intensity"
  ],
  "properties": {
    "match_id": { "type": "string" },
    "innings": { "type": "integer", "minimum": 1 },
    "over": { "type": "integer", "minimum": 0 },
    "ball": { "type": "integer", "minimum": 0, "maximum": 5 },
    "batting_team": { "type": "string" },
    "bowling_team": { "type": "string" },
    "striker": { "type": "string" },
    "non_striker": { "type": "string" },
    "bowler": { "type": "string" },
    "runs": { "type": "integer", "minimum": 0 },
    "wicket": { "type": "boolean" },
    "extras": { "type": "integer", "minimum": 0 },
    "current_score": { "type": "integer", "minimum": 0 },
    "wickets_lost": { "type": "integer", "minimum": 0, "maximum": 10 },
    "required_rr": { "type": "number", "minimum": 0 },
    "current_rr": { "type": "number", "minimum": 0 },
    "target": { "type": "integer", "minimum": 0 },
    "balls_remaining": { "type": "integer", "minimum": 0 },
    "recent_runs": { "type": "integer", "minimum": 0 },
    "recent_wickets": { "type": "integer", "minimum": 0 },
    "dot_ball_streak": { "type": "integer", "minimum": 0 },
    "partnership_runs": { "type": "integer", "minimum": 0 },
    "partnership_balls": { "type": "integer", "minimum": 0 },
    "phase_of_match": { "type": "string" },
    "win_probability": { "type": "number", "minimum": 0, "maximum": 1 },
    "momentum_state": { "type": "string", "enum": ["BATTING", "BOWLING", "NEUTRAL"] },
    "pressure_level": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "EXTREME"] },
    "collapse_risk": { "type": "number", "minimum": 0, "maximum": 1 },
    "commentary_text": { "type": "string" },
    "commentary_type": { "type": "string" },
    "tone": { "type": "string" },
    "importance": { "type": "string", "enum": ["low", "medium", "high"] },
    "pressure_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "momentum_score": { "type": "number", "minimum": -100, "maximum": 100 },
    "collapse_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "partnership_strength": { "type": "number", "minimum": 0, "maximum": 100 },
    "boundary_frequency": { "type": "number", "minimum": 0, "maximum": 1 },
    "dot_ball_pressure": { "type": "number", "minimum": 0, "maximum": 1 },
    "probability_swing": { "type": "number", "minimum": 0, "maximum": 1 },
    "death_over_intensity": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": true
}
