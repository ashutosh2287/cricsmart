{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cricsmart.dev/schemas/ball_state.schema.json",
  "title": "CricSmartBallState",
  "type": "object",
  "required": [
    "matchId",
    "source",
    "format",
    "innings",
    "over",
    "ball",
    "timestamp",
    "battingTeam",
    "bowlingTeam",
    "batsman",
    "nonStriker",
    "bowler",
    "eventType",
    "runs",
    "totalRuns",
    "isLegalDelivery",
    "wicket",
    "scoreAfterBall",
    "wicketsAfterBall"
  ],
  "properties": {
    "matchId": { "type": "string" },
    "source": { "type": "string", "enum": ["historical", "live", "mock", "simulation", "replay"] },
    "format": { "type": "string", "enum": ["T20", "ODI", "TEST"] },
    "innings": { "type": "integer", "minimum": 1, "maximum": 4 },
    "over": { "type": "integer", "minimum": 0 },
    "ball": { "type": "integer", "minimum": 0, "maximum": 5 },
    "timestamp": { "type": "integer", "minimum": 0 },
    "battingTeam": { "type": "string" },
    "bowlingTeam": { "type": "string" },
    "batsman": { "type": "string" },
    "nonStriker": { "type": "string" },
    "bowler": { "type": "string" },
    "eventType": { "type": "string", "enum": ["RUN", "FOUR", "SIX", "WICKET", "WD", "NB", "BYE", "LB"] },
    "runs": { "type": "integer", "minimum": 0 },
    "totalRuns": { "type": "integer", "minimum": 0 },
    "isLegalDelivery": { "type": "boolean" },
    "wicket": { "type": "boolean" },
    "extra": { "type": "boolean" },
    "extraType": { "type": ["string", "null"] },
    "scoreAfterBall": { "type": "integer", "minimum": 0 },
    "wicketsAfterBall": { "type": "integer", "minimum": 0, "maximum": 10 },
    "target": { "type": ["integer", "null"], "minimum": 1 },
    "matchWonByBattingSide": { "type": ["boolean", "null"] }
  },
  "additionalProperties": true
}
